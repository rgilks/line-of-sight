digraph SystemOverview {
  graph [
    rankdir=TB,
    bgcolor="#ffffff",
    pad="0.55",
    nodesep="0.55",
    ranksep="0.85",
    splines=polyline,
    outputorder=edgesfirst,
    compound=true,
    newrank=true,
    forcelabels=true,
    fontname="Avenir",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><FONT POINT-SIZE="34"><B>System Overview</B></FONT></TD></TR>
      </TABLE>
    >,
    labelloc=t,
    labeljust=c
  ];

  node [
    shape=box,
    style="rounded,filled",
    margin="0.21,0.13",
    width=3.05,
    height=0.74,
    fixedsize=false,
    fontname="Avenir",
    fontsize=18,
    penwidth=2.4,
    fontcolor="#14213d",
    color="#2264c7",
    fillcolor="#eaf3ff:#ffffff",
    gradientangle=270
  ];

  edge [
    color="#263a59",
    fontname="Avenir",
    fontsize=13,
    fontcolor="#3d4a5c",
    penwidth=2.2,
    arrowsize=0.78
  ];

  // ---- Browser: one Vite build, three apps + the generator (blue) ----
  subgraph cluster_browser {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1f5fb0"><B>BROWSER</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#3f6ea5">One Vite build serves four routes from web/.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t,
      labeljust=l,
      color="#bcd8f7",
      fillcolor="#f3f9ff",
      style="rounded,filled",
      penwidth=1.8,
      margin=20
    ];

    ED [label=<<B>Map editor</B><BR/><FONT POINT-SIZE="15">/edit · author, detect, export</FONT>>, fillcolor="#edf7ff:#ffffff", color="#2f80ed"];
    TB [label=<<B>Multiplayer table</B><BR/><FONT POINT-SIZE="15">/ host · /play · per-POV fog</FONT>>, fillcolor="#edf7ff:#ffffff", color="#2f80ed"];
    SO [label=<<B>Survive the Horde</B><BR/><FONT POINT-SIZE="15">/solo · single-player game</FONT>>, fillcolor="#edf7ff:#ffffff", color="#2f80ed"];
    SY [label=<<B>Synthetic generator</B><BR/><FONT POINT-SIZE="15">web/src/synth · seeded decks</FONT>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
  }

  // ---- Shared deterministic core (purple) ----
  subgraph cluster_core {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#5f3b8a"><B>SHARED CORE — core/</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#6d4d8d">Pure TypeScript. No DOM, no Cloudflare. Used by every app and the Worker.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t,
      labeljust=l,
      color="#d6c6ee",
      fillcolor="#fbf8ff",
      style="rounded,filled",
      penwidth=1.8,
      margin=20
    ];

    LOS [label=<<B>los</B><BR/><FONT POINT-SIZE="15">line of sight + wall/door detection</FONT>>, fillcolor="#f5f3ff:#ffffff", color="#7c3aed"];
    RU [label=<<B>rules</B><BR/><FONT POINT-SIZE="15">Cepheus movement, initiative, model</FONT>>, fillcolor="#f5f3ff:#ffffff", color="#7c3aed"];
    PF [label=<<B>pathfinding · dice</B><BR/><FONT POINT-SIZE="15">A* · seedable rolls</FONT>>, fillcolor="#f5f3ff:#ffffff", color="#7c3aed"];
  }

  // ---- Cloudflare Worker + table authority (green / teal) ----
  subgraph cluster_worker {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1e6b43"><B>CLOUDFLARE WORKER</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#4e7a61">Serves the static build; hosts the multiplayer table authority.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t,
      labeljust=l,
      color="#b8e5c8",
      fillcolor="#f4fbf6",
      style="rounded,filled",
      penwidth=1.8,
      margin=20
    ];

    WA [label=<<B>Static assets</B><BR/><FONT POINT-SIZE="15">dist/client (SPA fallback)</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
    DO [label=<<B>GameTable Durable Object</B><BR/><FONT POINT-SIZE="15">one per table · server-authoritative</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
    R2 [label=<<B>Private R2</B><BR/><FONT POINT-SIZE="15">GM map storage</FONT>>, fillcolor="#e6fffb:#ffffff", color="#0f766e"];
  }

  // ---- Editor output (terminal green) ----
  SC [label=<<B>LOS sidecar JSON</B><BR/><FONT POINT-SIZE="15">clipboard or download</FONT>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.2];

  // ---- Edges ----
  WA -> ED [label="serves the SPA", lhead=cluster_browser];
  SY -> TB [label="generate deck"];
  SY -> SO [label="generate deck"];
  SY -> ED [style=dashed, color="#6b7280", fontcolor="#6b7280"];

  ED -> LOS [label="analyze + visibility", lhead=cluster_core];
  ED -> SC [label="reviewed occluders"];
  SO -> PF [label="rules · dice · A* · LOS", lhead=cluster_core];

  TB -> DO [label="commands + per-POV stream"];
  DO -> LOS [label="gate tokens by line of sight"];
  TB -> R2 [label="GM map (private)", style=dashed, color="#6b7280", fontcolor="#6b7280"];
}

{
  "name": "line-of-sight",
  "version": "0.1.0",
  "private": false,
  "description": "A TypeScript browser lab for map line-of-sight extraction and review.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run build:web",
    "build:web": "vite build",
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "diagrams": "node scripts/render-diagrams.mjs",
    "check:diagrams": "node scripts/check-diagrams.mjs",
    "check": "npm run typecheck && npm run test && npm run build && npm run check:diagrams",
    "test:e2e": "node scripts/e2e-multiplayer.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "playwright": "^1.52.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.4",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@preact/signals": "^2.9.1",
    "preact": "^10.29.2"
  }
}

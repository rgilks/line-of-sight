{
  "name": "line-of-sight",
  "version": "0.1.0",
  "private": false,
  "description": "A TypeScript browser lab for map line-of-sight extraction and review.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run build:web",
    "build:web": "vite build",
    "check": "npm run build && npm run test",
    "deploy": "npm run build && wrangler deploy",
    "dev": "vite --host 127.0.0.1",
    "test": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@preact/signals": "^2.9.1",
    "preact": "^10.29.2"
  }
}
